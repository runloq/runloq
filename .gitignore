# Private tracker data — never commit a user's database
state/
*.db
*.db-wal
*.db-shm
*.dump.sql
.last_seen_issue_at

# Local config (generated by `runloq init`, may contain user-specific paths)
runloq.config.toml
runloq.config.toml
.runloq/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/
*.egg-info/
build/
dist/

# Node / dashboard
# The resolved plist (contains absolute paths) is generated by install.sh from
# the .plist.template — never commit the resolved copy.
dashboard/com.*.prism-api.plist
dashboard/dev.prism.api.plist
node_modules/
.output/
.vite/
test-results/
playwright-report/
*.tsbuildinfo
# Allow the pre-built SPA so `pipx install .` from source works without
# a manual `npm run build` step. The dist is committed and kept fresh by CI.
!dashboard/web/dist/
!dashboard/web/dist/**

# OS
.DS_Store
